# Site — canonical production URL, used for metadata, OG tags, canonical
# links, robots.txt, and sitemap.xml. Leave unset to default to
# http://localhost:3000 for local development. See lib/seo/site.ts.
NEXT_PUBLIC_SITE_URL=

# Supabase — required for authentication. Leave unset to keep auth disabled
# (forms render but show a "not configured" error; all pages still build/run).
# See lib/supabase/env.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# CRM — base URL of the AIGENTIC Flows CRM app that authenticated sessions
# are handed off to after login. Leave unset to default to the production
# CRM domain. See lib/crm/handoff.ts.
NEXT_PUBLIC_CRM_URL=

# Analytics — all optional. Leave unset to keep analytics fully disabled.
# See lib/analytics.ts and components/shared/analytics-scripts.tsx.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Google Search Console — HTML tag verification token.
NEXT_PUBLIC_GSC_VERIFICATION=
