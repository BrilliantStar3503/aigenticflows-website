# Supabase — required for authentication. Leave unset to keep auth disabled
# (forms render but show a "not configured" error; all pages still build/run).
# See lib/supabase/env.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Analytics — all optional. Leave unset to keep analytics fully disabled.
# See lib/analytics.ts and components/shared/analytics-scripts.tsx.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Google Search Console — HTML tag verification token.
NEXT_PUBLIC_GSC_VERIFICATION=
